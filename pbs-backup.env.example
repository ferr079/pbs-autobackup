# pbs-backup configuration
# Copy to /etc/pbs-backup/pbs-backup.env and edit

# PBS host — the machine that runs Proxmox Backup Server
# This machine will be woken via WOL, and shut down after backup
PBS_HOST_MAC="aa:bb:cc:dd:ee:ff"
PBS_HOST_IP="192.168.1.253"

# PBS server — can be different from PBS_HOST (e.g. LXC container on PBS_HOST)
PBS_IP="192.168.1.150"
PBS_STORAGE="pbs-storage"

# PVE nodes to backup — one per line, format: name|ip|api_token
# API tokens: create in Datacenter > Permissions > API Tokens (PVEAuditor+Datastore.Allocate)
PVE_NODES="pve1|192.168.1.251|user@pam!backup=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
pve2|192.168.1.252|user@pam!backup=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Backup settings
BACKUP_MODE="snapshot"    # snapshot, suspend, or stop
COMPRESS="zstd"           # zstd, lzo, gzip, or none

# Timeouts (seconds)
MAX_BOOT_WAIT=180         # Max time to wait for PBS host to boot
MAX_TASK_WAIT=3600        # Max time to wait for all backups (1h)

# PBS maintenance (optional — leave empty to skip)
PBS_PRUNE_JOB="weekly-prune"   # Name of prune job configured in PBS
PBS_DATASTORE="datastore1"     # Datastore name for garbage collection
